{
  "manifestVersion": 1,
  "id": "relay-switch.markdown-archive",
  "name": "Markdown 归档",
  "version": "0.1.0-alpha.0",
  "description": "将本地 Claude Code 和 Codex CLI 会话导出为适合 Obsidian 使用的 Markdown。",
  "publisher": "relay-switch",
  "engines": {
    "relaySwitch": ">=1.0.0"
  },
  "entry": {
    "type": "nodePackage",
    "package": "@relay-switch/plugin-markdown-archive",
    "version": "0.1.0-alpha.0",
    "bin": "relay-switch-plugin-markdown-archive",
    "args": [
      "serve"
    ]
  },
  "contributes": {
    "commands": [
      {
        "id": "markdownArchive.syncNow",
        "title": "立即同步会话",
        "category": "归档"
      },
      {
        "id": "markdownArchive.openOutputDirectory",
        "title": "打开输出目录",
        "category": "归档"
      },
      {
        "id": "markdownArchive.openBrowser",
        "title": "打开会话浏览器",
        "category": "归档"
      }
    ],
    "settings": {
      "type": "object",
      "title": "Markdown 归档",
      "properties": {
        "archiveEnabled": {
          "type": "boolean",
          "title": "启用归档",
          "default": false
        },
        "outputDirectory": {
          "type": "string",
          "title": "输出目录",
          "description": "Markdown 文件和导出索引写入的目录。",
          "default": ""
        },
        "includeClaudeCode": {
          "type": "boolean",
          "title": "包含 Claude Code",
          "default": true
        },
        "includeCodexCLI": {
          "type": "boolean",
          "title": "包含 Codex CLI",
          "default": true
        },
        "autoSync": {
          "type": "boolean",
          "title": "自动同步",
          "default": false
        },
        "syncIntervalSeconds": {
          "type": "integer",
          "title": "同步间隔秒数",
          "default": 300
        },
        "includeSystemEvents": {
          "type": "boolean",
          "title": "包含系统事件",
          "default": false
        },
        "includeToolCalls": {
          "type": "boolean",
          "title": "包含工具调用",
          "default": true
        },
        "redactSecrets": {
          "type": "boolean",
          "title": "隐藏敏感信息",
          "default": true
        },
        "overwriteExisting": {
          "type": "boolean",
          "title": "覆盖已有文件",
          "default": true
        }
      }
    },
    "transcriptSources": [
      {
        "id": "claude-code",
        "title": "Claude Code",
        "kind": "local-jsonl"
      },
      {
        "id": "codex-cli",
        "title": "Codex CLI",
        "kind": "local-jsonl"
      }
    ],
    "conversationExporters": [
      {
        "id": "obsidian-markdown",
        "title": "Obsidian Markdown",
        "format": "markdown"
      }
    ],
    "backgroundTasks": [
      {
        "id": "markdownArchive.autoSync",
        "title": "自动同步会话",
        "minimumIntervalSeconds": 30
      }
    ],
    "pages": [
      {
        "id": "markdownArchive.browser",
        "title": "会话浏览器",
        "kind": "localhost"
      }
    ]
  },
  "permissions": [
    "tool.transcripts.read",
    "filesystem.userSelectedDirectory.write",
    "filesystem.pluginData",
    "background.task",
    "ui.page",
    "ui.toast",
    "network.localhost"
  ]
}
